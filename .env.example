# Contypio CMS — Environment Configuration
# Copy to .env and adjust values:  cp .env.example .env
# --------------------------------------------------

# Database
POSTGRES_DB=contypio
POSTGRES_USER=contypio
POSTGRES_PASSWORD=CHANGE_ME

# Security (generate with: openssl rand -base64 48)
SECRET_KEY=CHANGE_ME

# Admin account (created on first startup)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=CHANGE_ME
DEFAULT_ADMIN_NAME=Admin

# Tenant defaults
DEFAULT_TENANT_SLUG=default
DEFAULT_TENANT_NAME=My Website
DEFAULT_TENANT_DOMAIN=localhost

# Port — Admin UI will be available at http://localhost:3000
CONTYPIO_PORT=3000

# Seed demo content on first startup (set to false for empty CMS)
SEED_DEMO=true
