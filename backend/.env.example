# Database
DATABASE_URL=postgresql+asyncpg://cms_user:SICHERES_PASSWORT@cms-postgres:5432/cms_db

# Security (MUSS in Production geaendert werden!)
SECRET_KEY=ein-langer-zufaelliger-string-hier

# CORS (kommasepariert fuer mehrere Origins)
CORS_ORIGINS=["http://localhost:8061"]

# Uploads & Assets
UPLOAD_DIR=/app/uploads
API_ASSET_URL=http://localhost:8060

# JWT
JWT_EXPIRE_MINUTES=480

# Default Tenant (wird beim ersten Start angelegt)
DEFAULT_TENANT_SLUG=default
DEFAULT_TENANT_NAME=Meine Website
DEFAULT_TENANT_DOMAIN=localhost

# Default Admin (wird beim ersten Start angelegt)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=SICHERES_PASSWORT
DEFAULT_ADMIN_NAME=Admin

# Site Defaults (fuer Site Settings Global)
DEFAULT_SITE_NAME=Meine Website
DEFAULT_SITE_TAGLINE=

# Travel API (optional, nur wenn Travel-Blocks genutzt werden)
TRAVEL_API_URL=http://host.docker.internal:8101
